apiVersion: v1
kind: Secret
metadata:
  name: app-secrets
type: Opaque
stringData:
  # Connection string para o RDS PostgreSQL gerado pelo Terraform
  # Substitua <rds-endpoint> pelo valor exposto no output do Terraform
# Altera o valor de exemplo por valores únicos do seu ambiente
  database-url: "postgres://postgres:j71gb2hKOpasd!@<rds-endpoint>:5432/votacao_production?sslmode=disable"
  
  # Secret key do reCAPTCHA
  # Altera o valor de exemplo por valores únicos do seu ambiente
  recaptcha-secret-key: "6LeIxAcTAAAAAGG-vFI1TnRWxMZNFuojJ4WifJWe"
  
  # Secret key do Rails
  # Altera o valor de exemplo por valores únicos do seu ambiente
  rails-secret-key-base: "5f84d6ee178a9c2e0b5d8a9e7f86c2e35a90d8a7c2b5d4e3f2a1b0c9d8e7f6a5b4c3d2e1f0"
